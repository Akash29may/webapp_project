# Copy to .env and fill in. Never commit the real .env.
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database. Default = SQLite (leave DB_ENGINE unset). For Postgres:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=smartexam
# DB_USER=smartexam
# DB_PASSWORD=smartexam
# DB_HOST=localhost
# DB_PORT=5432

# CORS / CSRF (frontend dev origin)
FRONTEND_ORIGIN=http://localhost:5173

# AI provider. LLM_PROVIDER = anthropic | openai | mock
# Use 'mock' for local dev/tests (no network, deterministic output).
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
